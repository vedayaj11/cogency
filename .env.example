# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cogency
POSTGRES_USER=cogency
POSTGRES_PASSWORD=cogency_dev
DATABASE_URL=postgresql+asyncpg://cogency:cogency_dev@localhost:5432/cogency

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=cogency-default

# LLM providers
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_TRIAGE_MODEL=claude-haiku-4-5
ANTHROPIC_JUDGE_MODEL=claude-opus-4-5

# Embeddings / rerank
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large
VOYAGE_RERANK_MODEL=rerank-2.5

# Langfuse (self-hosted)
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# WorkOS auth (B2B)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# Salesforce per-tenant connection (test/dev defaults; tenant configs live in DB)
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_JWT_PRIVATE_KEY_PATH=./secrets/sf_jwt.pem
SF_PUBSUB_ENDPOINT=api.pubsub.salesforce.com:7443

# App
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me
